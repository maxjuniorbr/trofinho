# Supabase
# Copie este arquivo para .env.local e preencha com os valores do seu projeto Supabase
# (https://supabase.com/dashboard → Settings → API)

EXPO_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=SEU_ANON_KEY_AQUI

# Sentry — Error monitoring
# DSN: Sentry → Settings → Client Keys (DSN)
# É seguro deixar no código (EXPO_PUBLIC_ = bundle público), mas prefira env var.
EXPO_PUBLIC_SENTRY_DSN=https://xxxxx@oXXXXXX.ingest.us.sentry.io/XXXXXXX

# Sentry auth token — usado apenas no build time para upload de source maps
# Não vai para o bundle do app. Cadastre no EAS (não commite o valor aqui):
# eas env:create --scope project --name SENTRY_AUTH_TOKEN --type string --visibility secret --environment preview
# Obtenha em: Sentry → Settings → Auth Tokens
SENTRY_AUTH_TOKEN=
