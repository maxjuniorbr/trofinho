{
  "expo": {
    "name": "Trofinho",
    "slug": "trofinho",
    "version": "1.0.0",
    "scheme": "trofinho",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/trofinho-mascot.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.maxjuniorbr.trofinho",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.maxjuniorbr.trofinho",
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#1e1e28",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "experiments": {
      "reactCompiler": true
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#C8860A"
        }
      ],
      "expo-secure-store",
      "expo-font",
      "expo-image",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8493d389-e92f-4a23-854d-bea1b62ae83a"
      }
    },
    "owner": "maxjuniorbrs-organization"
  }
}
