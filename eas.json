{
  "cli": {
    "version": ">= 18.4.0",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "android": {
        "preInstall": "bash scripts/eas-build-pre-install.sh"
      }
    },
    "development": {
      "extends": "base",
