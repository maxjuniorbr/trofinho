{
  "name": "trofinho",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "tunnel": "expo start --tunnel",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "android:devices": "adb devices",
    "android:screenshot": "mkdir -p .tmp && adb exec-out screencap -p > .tmp/screen.png",
    "android:ui": "mkdir -p .tmp && adb shell uiautomator dump /sdcard/window.xml && adb pull /sdcard/window.xml .tmp/window.xml",
    "android:logs": "adb logcat *:S ReactNative:V ReactNativeJS:V",
    "android:logcat": "adb logcat | grep -E 'ReactNative|ReactNativeJS'",
    "test:e2e": "maestro test -e MAESTRO_EMAIL=$MAESTRO_EMAIL -e MAESTRO_PASSWORD=$MAESTRO_PASSWORD .maestro/login.yaml && maestro test -e MAESTRO_EMAIL=$MAESTRO_EMAIL -e MAESTRO_PASSWORD=$MAESTRO_PASSWORD .maestro/logout.yaml && maestro test -e MAESTRO_EMAIL=$MAESTRO_EMAIL .maestro/login-wrong-password.yaml && maestro test .maestro/login-empty-fields.yaml",
    "test:e2e:login": "maestro test -e MAESTRO_EMAIL=$MAESTRO_EMAIL -e MAESTRO_PASSWORD=$MAESTRO_PASSWORD .maestro/login.yaml",
    "test:e2e:logout": "maestro test -e MAESTRO_EMAIL=$MAESTRO_EMAIL -e MAESTRO_PASSWORD=$MAESTRO_PASSWORD .maestro/logout.yaml",
    "test:e2e:create-account": "maestro test -e MAESTRO_REGISTER_PASSWORD=$MAESTRO_REGISTER_PASSWORD .maestro/create-account.yaml",
    "test:e2e:login-wrong-password": "maestro test -e MAESTRO_EMAIL=$MAESTRO_EMAIL .maestro/login-wrong-password.yaml",
    "test:e2e:login-empty-fields": "maestro test .maestro/login-empty-fields.yaml",
    "db:diff": "supabase db diff",
    "db:push": "supabase db push",
    "db:types": "npx supabase gen types typescript --linked > src/types/database.types.ts",
    "db:seed": "supabase db query --linked -f temp/seed-test-data.sql",
    "build": "EAS_BUILD_NO_EXPO_GO_WARNING=true npx eas-cli@latest build --profile preview --platform android",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@expo-google-fonts/nunito": "^0.4.2",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native-community/netinfo": "11.5.2",
    "@react-native-community/slider": "5.2.0",
    "@sentry/react-native": "^8.7.0",
    "@shopify/flash-list": "^2.3.1",
    "@supabase/supabase-js": "^2.101.1",
    "@tanstack/react-query": "^5.96.2",
    "expo": "~55.0.15",
    "expo-application": "~55.0.14",
    "expo-clipboard": "~55.0.13",
    "expo-constants": "~55.0.11",
    "expo-crypto": "~55.0.14",
    "expo-dev-client": "~55.0.27",
    "expo-device": "~55.0.15",
    "expo-file-system": "~55.0.14",
    "expo-font": "~55.0.6",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.8",
    "expo-image-manipulator": "~55.0.15",
    "expo-image-picker": "~55.0.18",
    "expo-linear-gradient": "~55.0.13",
    "expo-linking": "~55.0.13",
    "expo-notifications": "~55.0.19",
    "expo-router": "~55.0.12",
    "expo-secure-store": "~55.0.13",
    "expo-splash-screen": "~55.0.18",
    "expo-status-bar": "~55.0.5",
    "expo-system-ui": "~55.0.15",
    "expo-updates": "~55.0.20",
    "lucide-react-native": "^1.7.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-native": "0.85.2",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.0",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "react-native-svg": "^15.15.4",
    "react-native-worklets": "0.8.1"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.2.10",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~55.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^3.10.1",
    "fast-check": "^4.7.0",
    "prettier": "^3.8.3",
    "skills": "^1.5.1",
    "supabase": "^2.95.2",
    "test-renderer": "^0.15.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "overrides": {
    "@xmldom/xmldom": "^0.8.13",
    "postcss": "^8.5.10"
  },
  "private": true,
  "expo": {
    "install": {
      "exclude": [
        "typescript",
        "@sentry/react-native",
        "@shopify/flash-list",
        "react-native-safe-area-context",
        "react-native-screens",
        "react-native-svg"
      ]
    }
  }
}
