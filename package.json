{
  "name": "trofinho",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "tunnel": "expo start --tunnel",
    "test": "vitest run",
