{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "strict": true,
    "types": [
      "vitest/globals"
    ],
    "paths": {
      "@lib/*": [
        "./lib/*"
      ],
      "@/*": [
        "./src/*"
      ],
      "@types/*": [
        "./src/types/*"
      ]
    }
  },
  "exclude": [
    "coverage",
    "dist",
    "node_modules",
    "supabase/functions/**/index.ts"
  ]
}