{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "strict": true,
    "types": ["vitest/globals"],
    "paths": {
      "@lib/*": ["./lib/*"],
      "@/*": ["./src/*"],
      "@types/*": ["./src/types/*"]
    }
  },
  "exclude": ["coverage", "dist", "node_modules", "supabase/functions/**/index.ts"]
}
